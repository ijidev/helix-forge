{
    "name": "helix/forge",
    "description": "Helix-Forge: The AI-native PHP framework for building APIs and web apps 10x faster with agents.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "erusev/parsedown": "^1.8",
        "psr/container": "^2.0",
        "symfony/console": "^7.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Helix\\": "src/Helix/",
            "App\\": "app/"
        }
    },
    "bin": ["helix"],
    "scripts": {
        "post-create-project-cmd": "php setup.php",
        "post-install-cmd": "php setup.php",
        "serve": "@php helix serve",
        "test": "vendor/bin/pest"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
